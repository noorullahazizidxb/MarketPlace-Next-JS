# ==============================================================================
# FRONTEND ENVIRONMENT VARIABLES BLUEPRINT
# ==============================================================================

# API Base URLs
NEXT_PUBLIC_API_BASE=http://localhost:4000/api
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api

# Realtime WebSocket URLs
NEXT_PUBLIC_WS_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# Origins Strategy
BLOG_ORIGIN=http://localhost:3000
MARKETPLACE_ORIGIN=http://localhost:3001

# Elastic Search UI Flag
NEXT_PUBLIC_ENABLE_ELASTIC_SEARCH=true

# Google OAuth Setup
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
NEXT_PUBLIC_GOOGLE_AUTH_URL=/api/auth/google

# Facebook OAuth Setup
NEXT_PUBLIC_FACEBOOK_APP_ID=replace-with-facebook-app-id
FACEBOOK_APP_ID=replace-with-facebook-app-id
FACEBOOK_APP_SECRET=replace-with-facebook-app-secret
NEXT_PUBLIC_FACEBOOK_AUTH_URL=/api/auth/facebook

# Security & Sessions
SESSION_SECRET=replace-with-secure-random-value-at-least-32-chars
