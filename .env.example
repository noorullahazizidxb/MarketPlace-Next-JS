# Copy this file to `.env` (do not commit secrets) and update values for your environment.
#
# Public-facing base URLs used by the frontend. Prefer the new keys below. The code
# will fall back to the legacy names for backwards-compatibility.
NEXT_PUBLIC_API_BASE=http://localhost:3002/api
# legacy fallback (optional)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3002/api
NEXT_PUBLIC_ENABLE-ELASTIC-SEARCH=true
BLOG_ORIGIN="http://localhost:3000"
MARKETPLACE_ORIGIN="http://localhost:3001"

# WebSocket / Socket.IO URL for realtime events. Prefer this key.
NEXT_PUBLIC_WS_URL=http://localhost:4000
# legacy fallback (optional)
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# Session secret (server-side). For local development you can set a value but keep
# a real secret in production and server-only. Some dev flows read NEXT_PUBLIC_SESSION_SECRET
# when running purely client-side in dev; prefer server-side SESSION_SECRET.
SESSION_SECRET=replace-with-secure-random-value
# Optional dev-only public session secret (only use for local dev/testing)
NEXT_PUBLIC_SESSION_SECRET=dev-session-secret

# Optional DB URL used by backend (if applicable)
#DATABASE_URL=postgres://user:pass@localhost:5432/dbname

# Optional: additional runtime flags
#NODE_ENV=development   client iD: 835821235555-l2ir1fiktms787e30evhfr0hsnkfhuaf.apps.googleusercontent.com
DATABASE_URL="mysql://root:Mcitp@123@localhost:3306/marketplace"
NEXT_PUBLIC_API_BASE_URL="http://192.168.11.205:3002/api"
PORT="3005"

API_BASE="http://192.168.11.205:3002/api"

# Optional basic auth for Elasticsearch
ELASTICSEARCH_USERNAME="elastic"
ELASTICSEARCH_PASSWORD="Mcitp@123"
ELASTICSEARCH_INDEX_USERS="users"
ELASTICSEARCH_INDEX="listings"
ELASTICSEARCH_URL="https://192.168.11.205:9200"
