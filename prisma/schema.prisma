// Prisma schema for marketplace app
datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  USER
  REPRESENTATIVE
}

enum ListingType {
  RENT
  SALE
}

enum ListingStatus {
  PENDING
  APPROVED
  REJECTED
  SOLD
  RENTED
  EXPIRED
  DRAFT
  HIDDEN
}

enum ContactVisibility {
  HIDE_SELLER
  SHOW_SELLER
}

enum NotificationTargetType {
  USER
  ROLE
  ALL
  LISTING
}

enum NotificationChannel {
  SYSTEM
  EMAIL
  WHATSAPP
  PUSH
}

model User {
  id                String                  @id @default(cuid())
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  email             String?                 @unique
  phone             String?
  photo             String?
  firstName         String?
  lastName          String?
  fullName          String?
  contacts          Json?
  address           Json?
  passwordHash      String
  roles             UserRole[]
  listings          Listing[]
  representative    RepresentativeInfo?
  notifications     NotificationRecipient[]
  sentNotifications Notification[]          @relation("SenderNotifications")
  approvedListings  Listing[]               @relation("ListingApprovedBy")
  auditLogs         AuditLog[]
  feedbacks         ListingFeedback[]

  @@index([phone])
}

model UserRole {
  id     Int    @id @default(autoincrement())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  role   Role

  @@unique([userId, role])
}

model RepresentativeInfo {
  id             Int                     @id @default(autoincrement())
  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String                  @unique
  region         String
  whatsappNumber String?
  active         Boolean                 @default(true)
  listings       ListingRepresentative[]

  @@index([region])
  @@index([whatsappNumber])
}

model Category {
  id        Int        @id @default(autoincrement())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  name      String
  slug      String     @unique
  parentId  Int?
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  listings  Listing[]
  isActive  Boolean    @default(true)

  @@index([parentId])
}

model Listing {
  id                String                  @id @default(cuid())
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  title             String
  description       String
  price             Decimal                 @db.Decimal(12, 2)
  currency          String                  @default("AFN")
  listingType       ListingType
  status            ListingStatus           @default(PENDING)
  contactVisibility ContactVisibility       @default(HIDE_SELLER)
  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String
  category          Category                @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  categoryId        Int
  location          String?
  address           String?
  metadata          Json?
  approvedAt        DateTime?
  approvedById      String?
  approvedBy        User?                   @relation("ListingApprovedBy", fields: [approvedById], references: [id])
  expiresAt         DateTime?
  soldOrRentedAt    DateTime?
  images            ListingImage[]
  representatives   ListingRepresentative[]
  feedbacks         ListingFeedback[]
  searchIndex       SearchIndex?
  renewTokens       ListingRenewToken[]
  notifications     Notification[]          @relation("ListingNotifications")

  @@index([createdAt])
  @@index([listingType])
  @@index([status])
  @@index([userId])
  @@index([categoryId])
  @@index([location])
  @@index([expiresAt])
}

model ListingImage {
  id        Int     @id @default(autoincrement())
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String
  url       String
  position  Int     @default(0)
  alt       String?

  @@index([listingId])
}

model ListingRepresentative {
  id               Int                @id @default(autoincrement())
  listing          Listing            @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId        String
  representative   RepresentativeInfo @relation(fields: [representativeId], references: [id], onDelete: Cascade)
  representativeId Int
  assignedAt       DateTime           @default(now())

  @@unique([listingId, representativeId])
  @@index([listingId])
  @@index([representativeId])
}

model ListingFeedback {
  id          Int           @id @default(autoincrement())
  listing     Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId   String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  statusAfter ListingStatus
  rating      Int?
  comment     String?
  createdAt   DateTime      @default(now())

  @@index([listingId])
  @@index([userId])
}

model ListingRenewToken {
  id        Int      @id @default(autoincrement())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String   @unique
  token     String   @unique
  issuedAt  DateTime @default(now())
  expiresAt DateTime
  used      Boolean  @default(false)

  @@index([expiresAt])
}

model SearchIndex {
  id        Int      @id @default(autoincrement())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String   @unique
  payload   Json
  version   Int      @default(1)
  updatedAt DateTime @updatedAt
}

model Notification {
  id           String                  @id @default(cuid())
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  title        String
  message      String
  channel      NotificationChannel     @default(SYSTEM)
  targetType   NotificationTargetType
  sender       User?                   @relation("SenderNotifications", fields: [senderId], references: [id])
  senderId     String?
  listing      Listing?                @relation("ListingNotifications", fields: [listingId], references: [id])
  listingId    String?
  recipients   NotificationRecipient[]
  sentAt       DateTime?
  meta         Json?
  triggerEvent String?

  @@index([targetType])
  @@index([triggerEvent])
}

model NotificationRecipient {
  id             Int          @id @default(autoincrement())
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  notificationId String
  user           User?        @relation(fields: [userId], references: [id])
  userId         String?
  role           Role?
  readAt         DateTime?
  deliveredAt    DateTime?
  deliveryError  String?

  @@index([role])
  @@index([notificationId])
  @@index([userId])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  listingId String?
  action    String
  details   Json?
  ip        String?

  @@index([actorId])
  @@index([listingId])
  @@index([action])
}

model JobRecord {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now())
  queue       String
  jobId       String    @unique
  name        String
  payload     Json?
  status      String    @default("ENQUEUED")
  lastError   String?
  processedAt DateTime?

  @@index([queue])
  @@index([name])
  @@index([status])
}

model Themes {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String   @unique
  tokens    Json
  isActive  Boolean  @default(true)

  @@index([createdAt])
}
