# .env template for docker-configuration
# Fill these values before copying to the VPS.

# MySQL
MYSQL_ROOT_PASSWORD=Mcitp@123

# Git (if backend repo is private)
# If your backend repo is public leave this empty. If private, set your username here.
# Use your GitHub username for private repo access
GIT_USERNAME=noorullahazizidxb
# git password is provided via ./secrets/git_password.txt and used as a Docker secret

# Domains (replace example.com with your domains)
DOMAIN=marketplace.devminds.net
DOMAIN_API=api.devminds.net
DOMAIN_FRONT=marketplace.devminds.net
WWW_DOMAIN=blogs.devminds.net

# Contact
ADMIN_EMAIL=noorullah.azizi2040@gmail.com

# App secrets
TOKEN_SECRET=replace_with_random_token_secret
SESSION_SECRET=replace_with_random_session_secret

# Frontend env overrides
NEXT_PUBLIC_API_BASE=https://api.devminds.net/api
NEXT_PUBLIC_API_BASE_URL=https://api.devminds.net/api
NEXT_PUBLIC_WS_URL=https://api.devminds.net
BLOG_ORIGIN=https://blogs.devminds.net
MARKETPLACE_ORIGIN=https://marketplace.devminds.net

# Optional: change default DB URL if needed
# DATABASE_URL=mysql://root:Mcitp%40123@mysql:3306/marketplace