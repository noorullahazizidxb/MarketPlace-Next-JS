Content-Disposition: form-data; name="photo"; filename="me.jpg"
Content-Type: image/jpeg

< ./fixtures/me.jpg

### Update my profile
PUT {{host}}/users/me
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "firstName": "Noor",
  "lastName": "Azizi",
  "fullName": "Noor Azizi",
  "phone": "+93000000001",
  "photo": "/uploads/profiles/noor.jpg",
  "contacts": { "phone": "+93000000001", "whatsapp": "+93000000001" , "preferred": "whatsapp" },
  "address": { "street": "Street 10", "city": "Kabul", "country": "AF", "unit": "Apt 5" },
  "metadata": { "language": "en", "timezone": "Asia/Kabul" }
}

### Renew - issue token
POST {{host}}/renew/issue
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "listingId": "{{listingId}}"
}

### Renew - redeem token
POST {{host}}/renew/redeem
Content-Type: application/json

{
  "token": "PASTE_TOKEN_HERE",
  "redeemedBy": "{{token}}",
  "clientIp": "127.0.0.1"
}

### Notifications - send
POST {{host}}/notifications
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "Test Notification",
  "message": "This is a test",
  "channel": "WHATSAPP",
  "targetType": "USER",
  "recipientUserIds": ["{{userId}}"],
  "listingId": "{{listingId}}",
  "meta": { "urgent": true },
  "triggerEvent": "MANUAL_TEST"
}

### Roles - assign (admin)
POST {{host}}/roles/assign
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "userId": "2",
  "role": "REPRESENTATIVE",
  "assignedBy": "{{adminToken}}",
  "metadata": { "region": "Kabul" }
}

### Roles - list user roles (admin)
GET {{host}}/roles/user/{{userId}}
Authorization: Bearer {{adminToken}}

### Roles - list all role assignments (admin)
GET {{host}}/roles
Authorization: Bearer {{adminToken}}

### Users - list all users
GET {{host}}/users
Authorization: Bearer {{adminToken}}

### Users - get by id
GET {{host}}/users/{{userId}}
Authorization: Bearer {{adminToken}}

### Users - update by id
PUT {{host}}/users/{{userId}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "firstName": "Updated",
  "lastName": "User",
  "contacts": { "phone": "+93000000009" }
}

### Users - patch by id
PATCH {{host}}/users/{{userId}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "address": { "city": "Kabul" }
}

### Notifications - list
GET {{host}}/notifications
Authorization: Bearer {{adminToken}}

### Notifications - get by id
GET {{host}}/notifications/{{notificationId}}
Authorization: Bearer {{adminToken}}

### Notifications - patch
PATCH {{host}}/notifications/{{notificationId}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "readAt": "2025-09-10T12:00:00.000Z"
}

### Renew - list tokens
GET {{host}}/renew/tokens
Authorization: Bearer {{adminToken}}

### Renew - get token by id
GET {{host}}/renew/tokens/{{renewTokenId}}
Authorization: Bearer {{adminToken}}

### Renew - update token
PUT {{host}}/renew/tokens/{{renewTokenId}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "used": true
}

### Renew - patch token
PATCH {{host}}/renew/tokens/{{renewTokenId}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "expiresAt": "2025-12-31T00:00:00.000Z"
}

### Renew - delete token
DELETE {{host}}/renew/tokens/{{renewTokenId}}
Authorization: Bearer {{adminToken}}

